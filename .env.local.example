# ===== Firebase client (đọc điều ước đã duyệt) — NEXT_PUBLIC_* =====
# Lấy từ Firebase Console > Project settings > Your apps > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===== Firebase Admin (server-only: ghi pending + duyệt) =====
# Lấy từ Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Dán nguyên private key, giữ \n (escaped). Ví dụ: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ===== Mã quản trị để duyệt điều ước tại /admin =====
ADMIN_SECRET=doi-mat-khau-nay

# ===== Đăng nhập Google/Facebook (tự đăng ngay, khỏi chờ duyệt) =====
# KHÔNG cần biến env mới — dùng lại NEXT_PUBLIC_FIREBASE_* (client) + creds Admin (verifyIdToken).
# Cấu hình ở Firebase Console > Authentication > Sign-in method:
#   - Bật provider Google.
#   - Bật provider Facebook (cần tạo Facebook Developer App, dán App ID + App secret vào Console;
#     thêm OAuth redirect URI mà Firebase hiển thị vào Facebook App).
#   - Authentication > Settings > Authorized domains: thêm localhost + domain Vercel.
