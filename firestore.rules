rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Điều ước: client CHỈ được đọc bản đã duyệt.
    // Mọi ghi đi qua API route (Firebase Admin SDK) -> bỏ qua rules này.
    match /wishes/{id} {
      allow read: if resource.data.status == 'approved';
      allow write: if false;
    }

    // Phiên online phòng Rừng Trúc: ai cũng đọc được (không chứa PII).
    // Mọi ghi đi qua /api/presence (Admin SDK) -> bỏ qua rules này.
    match /sessions/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
